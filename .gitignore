# ---------------------------------------------------------------------------
# Confidential / personal data — MUST NEVER be committed.
# The de-identification originals live OUTSIDE this folder; this is a guard.
# ---------------------------------------------------------------------------
_CONFIDENTIAL_originals_DO_NOT_UPLOAD/
**/_CONFIDENTIAL_*/

# De-identification script kept local (per author): the one-time PII-stripping step.
scripts/00_deidentify.do

# Figures are shipped as PNG only; PDFs are not redistributed (keeps the package small).
results/**/*.pdf

# ---------------------------------------------------------------------------
# Large external public data (download per README: TCE-DAT, IBTrACS).
# ~634 MB; regenerates data/tce_dat/processed via scripts/R/01-02.
# ---------------------------------------------------------------------------
data/tce_dat/

# ---------------------------------------------------------------------------
# Run logs (leak local machine paths) and session scratch.
# ---------------------------------------------------------------------------
scripts/logs/
*.log
*.log.txt
*.smcl
.Rhistory
.RData
.Rproj.user/
*.gph.lock

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
